[run]
source =
    parcellation
    connectivity
    features
    ml_training
    source_reconstruction
    common
    analysis
    pipeline_mne_bids
    dashboard
omit =
    */__pycache__/*
    */tests/*
    */.planning/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise NotImplementedError
    ^\s*pass\s*$
show_missing = True
skip_covered = False
precision = 1
fail_under = 60

[html]
directory = htmlcov

[xml]
output = coverage.xml
